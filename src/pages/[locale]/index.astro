---
import { ModelBrowser } from "@/components/ModelBrowser";
import Layout from "@/layouts/Layout.astro";
import { fetchLLMModels } from "@/lib/llm-model-service";
import { LOCALES, t, type Locale } from "@/lib/translations";
import { isValidLocale } from "@/lib/utils";
import "@/styles/global.css";

const { locale } = Astro.params;

export async function getStaticPaths() {
  const models = await fetchLLMModels();
  const buildDate = new Date().toISOString().replace(/\.\d{3}Z$/, "Z");

  return LOCALES.map((locale) => ({
    params: { locale },
    props: { models, buildDate },
  }));
}

const { models, buildDate } = Astro.props;

const currentLocale = isValidLocale(locale)
  ? (locale as Locale)
  : ("en" satisfies Locale);
---

<Layout locale={locale}>
  <main class="container mx-auto py-10">
    <div class="mb-6 flex items-center gap-3">
      <h1 class="text-3xl font-bold">
        {t(currentLocale, "title")}
      </h1>
      <div class="flex items-center gap-2">
        <a
          href="https://github.com/likeablob/llm-api-price-table"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-md bg-black px-2 py-1 text-xs font-medium text-white hover:bg-gray-800 transition-colors"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mr-1"
          >
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
          GitHub
        </a>
        <a
          href="https://openrouter.ai/api/v1/models"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-md bg-gray-100 px-2 py-1 text-xs font-medium text-gray-900 hover:bg-gray-200 transition-colors"
          aria-label="Source"
        >
          Source: Openrouter
        </a>
      </div>
    </div>
    <ModelBrowser
      locale={currentLocale}
      models={models}
      buildDate={buildDate}
      client:load
    />
  </main>
</Layout>

<script is:inline>
  const preference = "${locale}";
  localStorage.setItem("i18n-preference", preference);
</script>
