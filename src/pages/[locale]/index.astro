---
import { ModelBrowser } from "@/components/ModelBrowser";
import Layout from "@/layouts/Layout.astro";
import { fetchLLMModels } from "@/lib/llm-model-service";
import { LOCALES, t, type Locale } from "@/lib/translations";
import { isValidLocale } from "@/lib/utils";
import "@/styles/global.css";

const { locale } = Astro.params;

export async function getStaticPaths() {
  const models = await fetchLLMModels();
  const buildDate = new Date().toISOString().replace(/\.\d{3}Z$/, "Z");

  return LOCALES.map((locale) => ({
    params: { locale },
    props: { models, buildDate },
  }));
}

const { models, buildDate } = Astro.props;

const currentLocale = isValidLocale(locale)
  ? (locale as Locale)
  : ("en" satisfies Locale);
---

<Layout locale={locale}>
  <main class="container mx-auto py-10">
    <div class="mb-6 flex items-center gap-3">
      <h1 class="text-3xl font-bold">
        {t(currentLocale, "title")}
      </h1>
      <div class="flex items-center gap-2">
        <a
          href="https://github.com/likeablob/llm-api-price-table"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-md border border-gray-300 bg-white px-2 py-1 text-xs font-medium text-gray-900 transition-colors hover:bg-gray-100"
          aria-label="GitHub"
        >
          <svg
            class="mr-1 h-3.5 w-3.5"
            role="img"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
            ><title>GitHub</title><path
              fill="currentColor"
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path></svg
          >
          GitHub
        </a>
        <a
          href="https://openrouter.ai/api/v1/models"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-md bg-gray-100 px-2 py-1 text-xs font-medium text-gray-900 transition-colors hover:bg-gray-200"
          aria-label="Source"
        >
          Data Source: OpenRouter
        </a>
      </div>
    </div>
    <ModelBrowser
      locale={currentLocale}
      models={models}
      buildDate={buildDate}
      client:load
    />
  </main>
</Layout>

<script define:vars={{ currentLocale }} is:inline>
  localStorage.setItem("i18n-preference", currentLocale);
</script>
