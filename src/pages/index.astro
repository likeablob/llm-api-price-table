---
/* ルートページはリダイレクトのみを担当 */
import { LOCALES, type Locale } from "@/lib/translations";

const localeMap = { en: "/en/", ja: "/ja/" } satisfies Record<Locale, string>;
---

<div
  data-locale-config={JSON.stringify({ validLocales: LOCALES, localeMap })}
  hidden
>
</div>

<script>
  (function () {
    const configElement = document.querySelector("[data-locale-config]");
    if (!configElement) return;

    const configJson = configElement.getAttribute("data-locale-config");
    if (!configJson) return;

    const config = JSON.parse(configJson);
    const { validLocales, localeMap } = config;

    const savedPreference = localStorage.getItem("i18n-preference");
    if (savedPreference && validLocales.includes(savedPreference)) {
      window.location.replace(localeMap[savedPreference]);
      return;
    }

    const browserLang = navigator.language.toLowerCase().split("-")[0];
    if (validLocales.includes(browserLang)) {
      window.location.replace(localeMap[browserLang]);
      return;
    }

    window.location.replace("/en/");
  })();
</script>
<html>
  <head>
    <meta http-equiv="refresh" content="1;url=/en/" />
  </head>
  <body>
    <p>Redirecting to <a href="/en/">English version</a>...</p>
  </body>
</html>
