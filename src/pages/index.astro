---
/* ルートページはリダイレクトのみを担当 */
import { LOCALES, type Locale } from "@/lib/translations";

const validLocales = LOCALES;
const defaultLocale: Locale = "en";
---

<div
  data-locale-config={JSON.stringify({ validLocales, defaultLocale })}
  hidden
>
</div>

<script>
  (function () {
    const configElement = document.querySelector("[data-locale-config]");
    if (!configElement) return;

    const configJson = configElement.getAttribute("data-locale-config");
    if (!configJson) return;

    const config = JSON.parse(configJson);
    const { validLocales, defaultLocale } = config;

    const savedPreference = localStorage.getItem("i18n-preference");
    if (
      savedPreference &&
      (validLocales as string[]).includes(savedPreference)
    ) {
      window.location.replace(`/${savedPreference}/`);
      return;
    }

    const browserLang = navigator.language.toLowerCase().split("-")[0];
    if ((validLocales as string[]).includes(browserLang)) {
      window.location.replace(`/${browserLang}/`);
      return;
    }

    window.location.replace(`/${defaultLocale}/`);
  })();
</script>
<html>
  <head>
    <meta http-equiv="refresh" content="1;url=/en/" />
  </head>
  <body>
    <p>Redirecting to <a href="/en/">English version</a>...</p>
  </body>
</html>
