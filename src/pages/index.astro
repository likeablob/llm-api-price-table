---
import { ModelBrowser } from "@/components/ModelBrowser";
import { fetchLLMModels } from "@/lib/llm-model-service";
import "@/styles/global.css";

const models = await fetchLLMModels();
const buildDate = new Date().toISOString().replace(/\.\d{3}Z$/, "Z");
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LLM Model Browser</title>
    <meta name="description" content="LLM モデルの価格比較ブラウザ" />
  </head>
  <body>
    <main class="container mx-auto py-10">
      <h1 class="mb-6 text-3xl font-bold">LLM Model Browser</h1>
      <ModelBrowser models={models} buildDate={buildDate} client:load />
    </main>
  </body>
</html>
